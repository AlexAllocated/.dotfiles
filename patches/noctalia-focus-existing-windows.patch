+void TrayWidget::focusItemWindow(const std::string& itemId) {
+  if (m_platform == nullptr) {
+    return;
+  }
+
+  const TrayItemInfo* item = nullptr;
+  for (const auto& candidate : m_items) {
+    if (candidate.id == itemId) {
+      item = &candidate;
+      break;
+    }
+  }
+  if (item == nullptr) {
+    return;
+  }
+
+  const auto runningApps = app_identity::resolveRunningApps(m_platform->runningAppIds(), desktopEntries());
+  const auto itemTokens = tray::pinMatchCandidates(*item);
+  const auto itemContains = [&itemTokens](std::string_view value) {
+    if (value.size() < 3) {
+      return false;
+    }
+    const std::string needle = StringUtils::toLower(std::string(value));
+    return std::ranges::any_of(itemTokens, [&needle](const std::string& token) {
+      return StringUtils::toLower(token).contains(needle);
+    });
+  };
+  for (const auto& running : runningApps) {
+    if (!tray::tokenMatchesItem(running.runningLower, *item)
+        && !tray::tokenMatchesItem(running.entry.id, *item)
+        && !tray::tokenMatchesItem(running.entry.startupWmClass, *item)
+        && !itemContains(running.runningLower)
+        && !itemContains(running.entry.nameLower)) {
+      continue;
+    }
+    const std::string wmClassLower =
+        running.entry.startupWmClassLower.empty() ? running.runningLower : running.entry.startupWmClassLower;
+    auto windows = m_platform->windowsForApp(running.runningLower, wmClassLower);
+    if (!windows.empty()) {
+      m_platform->activateToplevelInfo(windows.back());
+      return;
+    }
+  }
+}
