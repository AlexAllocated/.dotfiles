 void CompositorPlatform::activateToplevelInfo(const ToplevelInfo& window) {
+  // Native compositor IDs are more reliable than the generic Wayland
+  // activation request on compositors such as niri. In particular, niri may
+  // acknowledge the foreign-toplevel request without scrolling to the window.
+  if (!window.identifier.empty() && m_workspaceMetadataBackend != nullptr
+      && m_workspaceMetadataBackend->focusWindowById(window.identifier)) {
+    return;
+  }
+  // The generic wlr-foreign-toplevel protocol synthesizes identifiers from
+  // app-id/title, whereas niri's IPC exposes the numeric id required by its
+  // FocusWindow action. Resolve the protocol window against the compositor's
+  // live metadata before falling back to the best-effort Wayland request.
+  if (m_workspaceMetadataBackend != nullptr && !window.appId.empty() && !window.title.empty()) {
+    const auto tracked = m_workspaceMetadataBackend->workspaceWindows({});
+    for (auto it = tracked.rbegin(); it != tracked.rend(); ++it) {
+      if (it->appId == window.appId
+          && it->title == window.title
+          && !it->windowId.empty()
+          && m_workspaceMetadataBackend->focusWindowById(it->windowId)) {
+        return;
+      }
+    }
+  }
   if (window.handle != nullptr) {
     activateToplevel(window.handle);
     return;
