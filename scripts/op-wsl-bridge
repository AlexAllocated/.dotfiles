#!/usr/bin/env bash
set -euo pipefail

is_wsl() {
	[[ -n "${WSL_DISTRO_NAME:-}" ]] && return 0
	grep -qi microsoft /proc/version 2>/dev/null
}

script_path() {
	readlink -f "${BASH_SOURCE[0]}"
}

windows_home() {
	if [[ -n "${WINHOME:-}" && -d "$WINHOME" ]]; then
		printf '%s\n' "$WINHOME"
		return 0
	fi

	if [[ -d "/mnt/c/Users/${USER}" ]]; then
		printf '/mnt/c/Users/%s\n' "$USER"
		return 0
	fi

	return 1
}

find_windows_op() {
	local candidate

	if command -v op.exe >/dev/null 2>&1; then
		command -v op.exe
		return 0
	fi

	local winhome=""
	winhome="$(windows_home 2>/dev/null || true)"

	if [[ -n "$winhome" ]]; then
		local winhome_candidates=(
			"$winhome/AppData/Local/Microsoft/WindowsApps/op.exe"
			"$winhome/AppData/Local/Microsoft/WindowsApps/Microsoft.DesktopAppInstaller_8wekyb3d8bbwe/op.exe"
			"$winhome/AppData/Local/Microsoft/WinGet/Packages"/AgileBits.1Password.CLI_*/op.exe
		)

		for candidate in "${winhome_candidates[@]}"; do
			if [[ -x "$candidate" ]]; then
				printf '%s\n' "$candidate"
				return 0
			fi
		done
	fi

	local system_candidates=(
		"/mnt/c/Program Files/1Password CLI/op.exe"
		"/mnt/c/Program Files (x86)/1Password CLI/op.exe"
	)

	for candidate in "${system_candidates[@]}"; do
		if [[ -x "$candidate" ]]; then
			printf '%s\n' "$candidate"
			return 0
		fi
	done

	return 1
}

find_native_op() {
	local self
	self="$(script_path)"

	local dir candidate real_candidate
	IFS=':' read -r -a path_entries <<<"${PATH:-}"
	for dir in "${path_entries[@]}"; do
		[[ -n "$dir" ]] || continue
		candidate="$dir/op"
		[[ -x "$candidate" ]] || continue
		real_candidate="$(readlink -f "$candidate")"
		[[ "$real_candidate" != "$self" ]] || continue
		printf '%s\n' "$candidate"
		return 0
	done

	return 1
}

add_wslenv_name() {
	local name="$1"
	[[ -n "$name" ]] || return 0
	[[ ":${WSLENV:-}:" == *":${name}:"* ]] && return 0
	export WSLENV="${WSLENV:+$WSLENV:}${name}"
}

forward_op_environment() {
	local name
	while IFS='=' read -r name _; do
		[[ "$name" == OP_* ]] || continue
		add_wslenv_name "$name"
	done < <(env)
}

main() {
	if is_wsl; then
		local windows_op=""
		windows_op="$(find_windows_op 2>/dev/null || true)"
		if [[ -n "$windows_op" ]]; then
			export OP_BIOMETRIC_UNLOCK_ENABLED="${OP_BIOMETRIC_UNLOCK_ENABLED:-true}"
			add_wslenv_name OP_BIOMETRIC_UNLOCK_ENABLED
			forward_op_environment
			exec "$windows_op" "$@"
		fi
	fi

	local native_op=""
	native_op="$(find_native_op 2>/dev/null || true)"
	if [[ -n "$native_op" ]]; then
		exec "$native_op" "$@"
	fi

	printf 'op: no 1Password CLI found. Install the Windows CLI for WSL or native 1Password CLI for this host.\n' >&2
	exit 127
}

main "$@"
