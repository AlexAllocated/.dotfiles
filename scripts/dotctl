#!/usr/bin/env bash
set -euo pipefail

SCRIPT_SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$SCRIPT_SOURCE" ]]; do
	SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_SOURCE")" && pwd)"
	SCRIPT_SOURCE="$(readlink "$SCRIPT_SOURCE")"
	[[ "$SCRIPT_SOURCE" != /* ]] && SCRIPT_SOURCE="$SCRIPT_DIR/$SCRIPT_SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_SOURCE")" && pwd)"
SCRIPT_REPO_ROOT="$(cd -P "$SCRIPT_DIR/.." && pwd)"
if [[ -d "${DOTFILES_ROOT:-}" ]]; then
	REPO_ROOT="$DOTFILES_ROOT"
elif [[ -d "$HOME/.dotfiles" ]]; then
	REPO_ROOT="$HOME/.dotfiles"
else
	REPO_ROOT="$SCRIPT_REPO_ROOT"
fi

# shellcheck source=scripts/lib/common.sh
source "$SCRIPT_DIR/lib/common.sh"
# shellcheck source=scripts/profiles/macos-managed.sh
source "$SCRIPT_DIR/profiles/macos-managed.sh"
# shellcheck source=scripts/commands/update.sh
source "$SCRIPT_DIR/commands/update.sh"
# shellcheck source=scripts/commands/apply.sh
source "$SCRIPT_DIR/commands/apply.sh"
# shellcheck source=scripts/commands/doctor.sh
source "$SCRIPT_DIR/commands/doctor.sh"

usage() {
	cat <<'EOF'
Usage: dotctl <command> [profile] [options]

Commands:
  apply [profile] [--update]  Apply a NixOS, Home Manager, nix-darwin, or managed macOS profile.
  update [profile]            Refresh pins transactionally without applying them.
  check                       Run repository checks for every supported system.
  doctor                      Diagnose the active environment.
  codex-share <command>       Diagnose or migrate the Windows/WSL shared Codex home.

Profiles:
  chev-desktop
  nixos-wsl
  linux
  macos-managed
  macos
  darwin-macos
EOF
}

run_codex_share() {
	local helper="$REPO_ROOT/scripts/codex/share.py"
	[[ -f "$helper" ]] || {
		printf 'Codex sharing helper not found: %s\n' "$helper" >&2
		return 1
	}
	require_command python3
	python3 "$helper" "$@"
}

main() {
	local command="${1:-}"
	[[ -n "$command" ]] || {
		usage
		return 2
	}
	shift
	case "$command" in
		apply)
			local profile=""
			local update=0
			while (($#)); do
				case "$1" in
					--update) update=1 ;;
					*) profile="$1" ;;
				esac
				shift
			done
			profile="${profile:-$(detect_profile)}"
			ensure_git_identity
			if ((update)); then
				apply_with_update "$profile"
			else
				apply_profile "$profile"
			fi
			;;
		update)
			run_update "${1:-$(detect_profile)}"
			print_repo_status
			;;
		check) run_check ;;
		doctor) run_doctor ;;
		codex-share) run_codex_share "$@" ;;
		-h | --help | help) usage ;;
		*)
			printf 'Unknown command: %s\n' "$command" >&2
			usage >&2
			return 2
			;;
	esac
}

main "$@"
