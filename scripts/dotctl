#!/usr/bin/env bash
set -euo pipefail

SCRIPT_SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$SCRIPT_SOURCE" ]]; do
	SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_SOURCE")" && pwd)"
	SCRIPT_SOURCE="$(readlink "$SCRIPT_SOURCE")"
	[[ "$SCRIPT_SOURCE" != /* ]] && SCRIPT_SOURCE="${SCRIPT_DIR}/${SCRIPT_SOURCE}"
done
SCRIPT_REPO_ROOT="$(cd -P "$(dirname "$SCRIPT_SOURCE")/.." && pwd)"
if [[ -d "${DOTFILES_ROOT:-}" ]]; then
	REPO_ROOT="$DOTFILES_ROOT"
elif [[ -d "$HOME/.dotfiles" ]]; then
	REPO_ROOT="$HOME/.dotfiles"
else
	REPO_ROOT="$SCRIPT_REPO_ROOT"
fi

usage() {
	cat <<'EOF'
Usage: dotctl <command> [profile] [options]

Commands:
  apply [profile] [--update] [--recreate]
                                Apply a NixOS, nix-darwin, or Home Manager profile.
  shell [profile]              Open an interactive shell for a container profile.
  import-host-state [profile]  Copy host auth/config state into a container profile.
  workshop-update              Rebuild a workshop image from the current checkout.
  host <ping|op ...>           Run an allowlisted macOS host integration command.
  update                       Update all repo-managed pins.
  check                        Run flake checks.
  doctor                       Print host integration diagnostics.

Profiles:
  nixos-wsl       NixOS running inside WSL.
  linux           Home Manager only, any Linux with Nix.
  macos-docker    Managed macOS host using the dotfiles Linux Docker container.
  macos           Home Manager only, Apple Silicon macOS.
  macos-intel     Home Manager only, Intel macOS.
  darwin-macos    nix-darwin Apple Silicon system profile.
  darwin-macos-intel
                  nix-darwin Intel system profile.

EOF
}

command_exists() {
	command -v "$1" >/dev/null 2>&1
}

detect_profile() {
	if [[ -f /etc/NIXOS && -n "${WSL_DISTRO_NAME:-}" ]]; then
		printf 'nixos-wsl\n'
	elif [[ "$(uname -s)" == "Darwin" ]]; then
		if ! command_exists nix; then
			printf 'macos-docker\n'
			return
		fi
		if [[ "$(uname -m)" == "arm64" ]]; then
			printf 'macos\n'
		else
			printf 'macos-intel\n'
		fi
	else
		printf 'linux\n'
	fi
}

flake_ref_for_profile() {
	local profile="$1"

	case "$profile" in
		nixos-wsl)
			printf '%s#nixos-wsl\n' "$REPO_ROOT"
			;;
		linux)
			printf '%s#linux\n' "$REPO_ROOT"
			;;
		macos-docker)
			printf '%s#macos-docker\n' "$REPO_ROOT"
			;;
		macos)
			printf '%s#macos\n' "$REPO_ROOT"
			;;
		macos-intel)
			printf '%s#macos-intel\n' "$REPO_ROOT"
			;;
		darwin-macos)
			printf '%s#darwin-macos\n' "$REPO_ROOT"
			;;
		darwin-macos-intel)
			printf '%s#darwin-macos-intel\n' "$REPO_ROOT"
			;;
		*)
			printf 'Unknown profile: %s\n' "$profile" >&2
			exit 2
			;;
	esac
}

backup_path() {
	local path="$1"
	local backup_dir="$HOME/.backup_dotfiles"
	local stamp
	stamp="$(date +%Y%m%d%H%M%S)"

	mkdir -p "$backup_dir"
	mv "$path" "$backup_dir/$(basename "$path").$stamp"
	printf 'Backed up %s to %s\n' "$path" "$backup_dir/$(basename "$path").$stamp"
}

link_path() {
	local target="$1"
	local source="$2"

	if [[ -L "$target" ]]; then
		local current
		current="$(readlink "$target")"
		if [[ "$current" == "$source" ]]; then
			return 0
		fi
		backup_path "$target"
	elif [[ -e "$target" ]]; then
		backup_path "$target"
	fi

	mkdir -p "$(dirname "$target")"
	ln -s "$source" "$target"
	printf 'Linked %s -> %s\n' "$target" "$source"
}

remove_repo_link() {
	local target="$1"
	local source="$2"

	if [[ -L "$target" && "$(readlink "$target")" == "$source" ]]; then
		rm "$target"
		printf 'Removed host link %s -> %s\n' "$target" "$source"
	fi
}

apply_macos_host_links() {
	remove_repo_link "$HOME/.zprofile" "$REPO_ROOT/.zprofile"
	remove_repo_link "$HOME/.zshrc" "$REPO_ROOT/.zshrc"
	remove_repo_link "$HOME/.p10k.zsh" "$REPO_ROOT/.p10k.zsh"
	remove_repo_link "$HOME/.tool-versions" "$REPO_ROOT/.tool-versions"
	remove_repo_link "$HOME/rustfmt.toml" "$REPO_ROOT/rustfmt.toml"
	remove_repo_link "$HOME/.config/nvim" "$REPO_ROOT/nvim"
	link_path "$HOME/.wezterm.lua" "$REPO_ROOT/.wezterm.lua"
	link_path "$HOME/.config/wezterm" "$REPO_ROOT/wezterm"
	link_path "$HOME/.local/bin/dotctl" "$REPO_ROOT/scripts/dotctl"
}

write_macos_host_profile() {
	local profile="$1"
	mkdir -p "$HOME/.local/share/dotfiles"
	printf '%s\n' "$profile" >"$HOME/.local/share/dotfiles/profile"
}

git_identity_path() {
	printf '%s/.config/git/identity\n' "$HOME"
}

git_local_path() {
	printf '%s/.config/git/local\n' "$HOME"
}

git_config_value() {
	local key="$1"
	local file="${2:-}"

	if ! command_exists git; then
		return 0
	fi

	if [[ -n "$file" ]]; then
		git config --file "$file" --get "$key" 2>/dev/null || true
	else
		git config --global --get "$key" 2>/dev/null || true
	fi
}

write_git_identity() {
	local name="$1"
	local email="$2"
	local identity

	identity="$(git_identity_path)"
	mkdir -p "$(dirname "$identity")"
	cat >"$identity" <<EOF
[user]
	name = $name
	email = $email
EOF
	chmod 600 "$identity"
	printf 'Wrote Git identity to %s\n' "$identity"
}

ensure_git_identity() {
	local identity existing_name existing_email name email default_name default_email

	identity="$(git_identity_path)"
	existing_name="$(git_config_value user.name "$identity")"
	existing_email="$(git_config_value user.email "$identity")"

	if [[ -n "$existing_name" && -n "$existing_email" ]]; then
		return 0
	fi

	default_name="${DOTFILES_GIT_NAME:-$(git_config_value user.name)}"
	default_email="${DOTFILES_GIT_EMAIL:-$(git_config_value user.email)}"
	[[ -n "$default_name" ]] || default_name="Alex"

	if [[ -n "${DOTFILES_GIT_NAME:-}" && -n "${DOTFILES_GIT_EMAIL:-}" ]]; then
		write_git_identity "$DOTFILES_GIT_NAME" "$DOTFILES_GIT_EMAIL"
		return 0
	fi

	if [[ ! -t 0 || ! -t 1 ]]; then
		printf 'Git identity is not configured at %s.\n' "$identity" >&2
		printf 'Run interactively or set DOTFILES_GIT_NAME and DOTFILES_GIT_EMAIL before running dotctl apply.\n' >&2
		return 1
	fi

	printf 'Git identity is not configured for this environment.\n'
	printf 'Git author name [%s]: ' "$default_name"
	IFS= read -r name
	[[ -n "$name" ]] || name="$default_name"

	while [[ -z "${email:-}" ]]; do
		if [[ -n "$default_email" ]]; then
			printf 'Git author email [%s]: ' "$default_email"
		else
			printf 'Git author email: '
		fi
		IFS= read -r email
		[[ -n "$email" ]] || email="$default_email"
	done

	write_git_identity "$name" "$email"
}

ensure_homebrew() {
	if command_exists brew; then
		return 0
	fi

	if [[ -x /opt/homebrew/bin/brew ]]; then
		eval "$(/opt/homebrew/bin/brew shellenv)"
		return 0
	fi

	if [[ -x /usr/local/bin/brew ]]; then
		eval "$(/usr/local/bin/brew shellenv)"
		return 0
	fi

	if [[ "$(uname -s)" != "Darwin" ]]; then
		printf 'Homebrew is not installed and automatic install is only supported on macOS.\n' >&2
		return 1
	fi

	printf 'Homebrew is not installed; installing Homebrew...\n' >&2
	NONINTERACTIVE=1 /bin/bash -c "$(curl --fail -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)" >&2

	if [[ -x /opt/homebrew/bin/brew ]]; then
		eval "$(/opt/homebrew/bin/brew shellenv)"
	elif [[ -x /usr/local/bin/brew ]]; then
		eval "$(/usr/local/bin/brew shellenv)"
	fi

	if ! command_exists brew; then
		printf 'Homebrew installation finished, but brew is still not on PATH. Open a new shell and retry.\n' >&2
		return 1
	fi
}

brew_noninteractive() {
	HOMEBREW_NO_ASK=1 HOMEBREW_NO_ENV_HINTS=1 brew "$@"
}

ensure_wezterm() {
	if command_exists wezterm || [[ -d /Applications/WezTerm.app ]]; then
		return 0
	fi

	ensure_homebrew
	printf 'WezTerm is not installed; installing WezTerm with Homebrew...\n' >&2
	brew_noninteractive install --cask wezterm >&2
}

host_tool_command() {
	local cmd="$1"

	if command_exists "$cmd"; then
		command -v "$cmd"
	elif [[ -x "/opt/homebrew/bin/$cmd" ]]; then
		printf '/opt/homebrew/bin/%s\n' "$cmd"
	elif [[ -x "/usr/local/bin/$cmd" ]]; then
		printf '/usr/local/bin/%s\n' "$cmd"
	else
		return 1
	fi
}

ensure_homebrew_formula() {
	local cmd="$1"
	local formula="$2"

	if host_tool_command "$cmd" >/dev/null 2>&1; then
		return 0
	fi

	ensure_homebrew
	printf '%s is not installed; installing %s with Homebrew...\n' "$cmd" "$formula" >&2
	brew_noninteractive install "$formula" >&2

	if ! host_tool_command "$cmd" >/dev/null 2>&1; then
		printf '%s was not found after installation. Open a new shell and retry.\n' "$cmd" >&2
		return 1
	fi
}

onepassword_cli_command() {
	host_tool_command op
}

ensure_1password() {
	if [[ "$(uname -s)" != "Darwin" ]]; then
		return 0
	fi

	if [[ ! -d /Applications/1Password.app ]]; then
		ensure_homebrew
		printf '1Password is not installed; installing 1Password with Homebrew...\n' >&2
		brew_noninteractive install --cask 1password >&2
	fi

	if ! onepassword_cli_command >/dev/null 2>&1; then
		ensure_homebrew
		printf '1Password CLI is not installed; installing 1Password CLI with Homebrew...\n' >&2
		brew_noninteractive install --cask 1password-cli >&2
	fi

	if ! onepassword_cli_command >/dev/null 2>&1; then
		printf '1Password CLI was not found after installation. Open a new shell and retry.\n' >&2
		return 1
	fi
}

dotfiles_hostd_label() {
	printf 'com.alexallocated.dotfiles.hostd\n'
}

dotfiles_hostd_state_dir() {
	printf '%s/.local/share/dotfiles\n' "$HOME"
}

dotfiles_hostd_sock() {
	printf '%s\n' "${DOTFILES_HOSTD_SOCKET:-$(dotfiles_hostd_state_dir)/hostd.sock}"
}

dotfiles_hostd_container_sock() {
	printf '/run/host-services/dotfiles-hostd.sock\n'
}

dotfiles_hostd_enabled() {
	case "${DOTFILES_HOSTD:-1}" in
		0 | false | FALSE | no | NO)
			return 1
			;;
		*)
			return 0
			;;
	esac
}

macos_docker_hostd_sock() {
	if dotfiles_hostd_enabled && [[ "$(uname -s)" == "Darwin" ]]; then
		dotfiles_hostd_sock
	fi
}

ensure_hostd_dependencies() {
	ensure_homebrew_formula socat socat
	ensure_homebrew_formula jq jq
}

xml_escape() {
	sed \
		-e 's/&/\&amp;/g' \
		-e 's/</\&lt;/g' \
		-e 's/>/\&gt;/g' \
		-e 's/"/\&quot;/g' \
		-e "s/'/\&apos;/g"
}

write_dotfiles_hostd_service() {
	local state_dir socket label plist log_out log_err socat_bin dotctl_bin server_script handler_script
	local escaped_label escaped_server escaped_log_out escaped_log_err

	state_dir="$(dotfiles_hostd_state_dir)"
	socket="$(dotfiles_hostd_sock)"
	label="$(dotfiles_hostd_label)"
	plist="$HOME/Library/LaunchAgents/$label.plist"
	log_out="$state_dir/hostd.out.log"
	log_err="$state_dir/hostd.err.log"
	socat_bin="$(host_tool_command socat)"
	dotctl_bin="$REPO_ROOT/scripts/dotctl"
	server_script="$state_dir/hostd-server"
	handler_script="$state_dir/hostd-handler"

	mkdir -p "$state_dir" "$HOME/Library/LaunchAgents"

	cat >"$handler_script" <<EOF
#!/usr/bin/env bash
exec "$dotctl_bin" hostd-handle
EOF
	chmod 700 "$handler_script"

	cat >"$server_script" <<EOF
#!/usr/bin/env bash
set -euo pipefail
socket="$socket"
rm -f "\$socket"
mkdir -p "\$(dirname "\$socket")"
umask 077
exec "$socat_bin" "UNIX-LISTEN:\$socket,fork,unlink-early,mode=0600" "EXEC:$handler_script,nofork"
EOF
	chmod 700 "$server_script"

	escaped_label="$(printf '%s' "$label" | xml_escape)"
	escaped_server="$(printf '%s' "$server_script" | xml_escape)"
	escaped_log_out="$(printf '%s' "$log_out" | xml_escape)"
	escaped_log_err="$(printf '%s' "$log_err" | xml_escape)"

	cat >"$plist" <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>$escaped_label</string>
	<key>ProgramArguments</key>
	<array>
		<string>/bin/bash</string>
		<string>$escaped_server</string>
	</array>
	<key>RunAtLoad</key>
	<true/>
	<key>KeepAlive</key>
	<true/>
	<key>StandardOutPath</key>
	<string>$escaped_log_out</string>
	<key>StandardErrorPath</key>
	<string>$escaped_log_err</string>
</dict>
</plist>
EOF
	chmod 600 "$plist"
}

ensure_dotfiles_hostd() {
	local label plist socket service_target waited

	if [[ "$(uname -s)" != "Darwin" ]] || ! dotfiles_hostd_enabled; then
		return 0
	fi

	ensure_hostd_dependencies
	write_dotfiles_hostd_service

	label="$(dotfiles_hostd_label)"
	plist="$HOME/Library/LaunchAgents/$label.plist"
	socket="$(dotfiles_hostd_sock)"
	service_target="gui/$(id -u)"

	launchctl bootout "$service_target" "$plist" >/dev/null 2>&1 || true
	launchctl bootstrap "$service_target" "$plist" >/dev/null 2>&1 || launchctl load "$plist" >/dev/null 2>&1
	launchctl kickstart -k "$service_target/$label" >/dev/null 2>&1 || true

	waited=0
	while ((waited < 50)); do
		if [[ -S "$socket" ]]; then
			return 0
		fi
		sleep 0.1
		waited=$((waited + 1))
	done

	printf 'dotfiles hostd did not create %s. Check %s/hostd.err.log on the host.\n' "$socket" "$(dotfiles_hostd_state_dir)" >&2
	return 1
}

docker_command() {
	if command_exists docker; then
		command -v docker
	elif [[ -x /Applications/Docker.app/Contents/Resources/bin/docker ]]; then
		printf '/Applications/Docker.app/Contents/Resources/bin/docker\n'
	else
		return 1
	fi
}

ensure_docker() {
	local docker_bin=""
	if docker_bin="$(docker_command 2>/dev/null)"; then
		:
	elif [[ "$(uname -s)" == "Darwin" && -d /Applications/Docker.app ]]; then
		docker_bin="/Applications/Docker.app/Contents/Resources/bin/docker"
	else
		ensure_homebrew
		printf 'Docker is not installed; installing Docker Desktop with Homebrew...\n' >&2
		brew_noninteractive install --cask docker >&2
		docker_bin="$(docker_command 2>/dev/null || true)"
	fi

	if [[ -z "$docker_bin" || ! -x "$docker_bin" ]]; then
		printf 'Docker CLI was not found after installation. Start Docker Desktop and retry.\n' >&2
		return 1
	fi

	if "$docker_bin" info >/dev/null 2>&1; then
		printf '%s\n' "$docker_bin"
		return 0
	fi

	if [[ "$(uname -s)" == "Darwin" ]]; then
		printf 'Starting Docker Desktop...\n' >&2
		open -ga Docker || true
	fi

	local waited=0
	while ((waited < 180)); do
		if "$docker_bin" info >/dev/null 2>&1; then
			printf '%s\n' "$docker_bin"
			return 0
		fi
		sleep 3
		waited=$((waited + 3))
	done

	printf 'Docker did not become ready. Finish Docker Desktop first-run setup, then retry.\n' >&2
	return 1
}

provision_macos_docker_container() {
	local docker_bin="$1"
	local container="$2"

	"$docker_bin" exec "$container" /bin/bash -lc '
		set -euo pipefail

		link_path() {
			local target="$1"
			local source="$2"

			if [[ -L "$target" ]]; then
				ln -sfn "$source" "$target"
			elif [[ -e "$target" ]]; then
				mv "$target" "$target.container-backup.$(date +%Y%m%d%H%M%S)"
				ln -s "$source" "$target"
			else
				ln -s "$source" "$target"
			fi
		}

		mkdir -p "$HOME/.codex/rules" "$HOME/.config" "$HOME/.local/bin"
		mkdir -p "$HOME/code"
		link_path "$HOME/.zprofile" "$HOME/.dotfiles/.zprofile"
		link_path "$HOME/.zshrc" "$HOME/.dotfiles/.zshrc"
		link_path "$HOME/.gitconfig" "$HOME/.dotfiles/.gitconfig"
		link_path "$HOME/.p10k.zsh" "$HOME/.dotfiles/.p10k.zsh"
		link_path "$HOME/.tool-versions" "$HOME/.dotfiles/.tool-versions"
		link_path "$HOME/.wezterm.lua" "$HOME/.dotfiles/.wezterm.lua"
		link_path "$HOME/rustfmt.toml" "$HOME/.dotfiles/rustfmt.toml"
		link_path "$HOME/.config/nvim" "$HOME/.dotfiles/nvim"
		link_path "$HOME/.config/wezterm" "$HOME/.dotfiles/wezterm"
		link_path "$HOME/.codex/config.toml" "$HOME/.dotfiles/codex/config.toml"
		link_path "$HOME/.codex/rules/default.rules" "$HOME/.dotfiles/codex/rules/default.rules"
		link_path "$HOME/.local/bin/dotctl" "$HOME/.dotfiles/scripts/dotctl"

		if [[ -S /run/host-services/ssh-auth.sock ]]; then
			mkdir -p "$HOME/.1password" "$HOME/Library/Group Containers/2BUA8C4S2C.com.1password/t"
			ln -sfn /run/host-services/ssh-auth.sock "$HOME/.1password/agent.sock"
			ln -sfn /run/host-services/ssh-auth.sock "$HOME/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"
		fi

		if [[ ! -r /share/zsh-powerlevel10k/powerlevel10k.zsh-theme && ! -r "$HOME/.local/share/powerlevel10k/powerlevel10k.zsh-theme" ]] && command -v git >/dev/null 2>&1; then
			mkdir -p "$HOME/.local/share"
			git clone --depth 1 https://github.com/romkatv/powerlevel10k.git "$HOME/.local/share/powerlevel10k" >/dev/null 2>&1 || true
		fi

		if [[ ! -r /share/zsh-vi-mode/zsh-vi-mode.plugin.zsh && ! -r "$HOME/.local/share/zsh-vi-mode/zsh-vi-mode.plugin.zsh" ]] && command -v git >/dev/null 2>&1; then
			mkdir -p "$HOME/.local/share"
			git clone --depth 1 https://github.com/jeffreytse/zsh-vi-mode.git "$HOME/.local/share/zsh-vi-mode" >/dev/null 2>&1 || true
		fi
		'
}

prime_macos_docker_neovim() {
	local docker_bin="$1"
	local container="$2"
	local announce="${3:-1}"

	if [[ "${DOTCTL_DOCKER_PRIME_NVIM:-1}" == "0" ]]; then
		return 0
	fi

	if [[ "$announce" == "1" ]]; then
		printf 'Priming Neovim plugins, Mason registry, and Treesitter parsers in %s...\n' "$container"
	fi

	"$docker_bin" exec "$container" /bin/bash -lc '
		set -euo pipefail

		if ! command -v nvim >/dev/null 2>&1; then
			exit 0
		fi

		mkdir -p "$HOME/.cache/dotfiles" "$HOME/.local/share/dotfiles"
		stamp_file="$HOME/.local/share/dotfiles/nvim-bootstrap.sha256"
		log_file="$HOME/.cache/dotfiles/nvim-bootstrap.log"
		lock_file="$HOME/.local/share/dotfiles/lazy-lock.json"
		config_root="$HOME/.dotfiles/nvim"

		if [[ ! -d "$config_root" ]]; then
			exit 0
		fi

		stamp="$(
			find "$config_root" -type f -print0 |
				sort -z |
				xargs -0 sha256sum |
				sha256sum |
				awk "{print \$1}"
		)"

		if [[ -f "$stamp_file" ]] && [[ "$(cat "$stamp_file")" == "$stamp" ]]; then
			exit 0
		fi

		cp "$config_root/lazy-lock.json" "$lock_file"
		if DOTFILES_NVIM_AUTOMATION=1 DOTFILES_NVIM_LOCKFILE="$lock_file" nvim --headless "+set nomore" "+Lazy! restore" "+MasonUpdate" "+TSUpdateSync" "+lua require(\"config.bootstrap\").wait_for_mason()" +qa >"$log_file" 2>&1; then
			printf "%s\n" "$stamp" >"$stamp_file"
			exit 0
		fi

		printf "Neovim bootstrap failed. Last log lines from %s:\n" "$log_file" >&2
		tail -n 80 "$log_file" >&2 || true
		exit 1
	'
}

stage_path_if_exists() {
	local source="$1"
	local dest="$2"

	[[ -e "$source" || -L "$source" ]] || return 0
	mkdir -p "$(dirname "$dest")"
	if [[ -d "$source" && ! -L "$source" ]]; then
		mkdir -p "$dest"
		rsync -a \
			--no-devices \
			--no-specials \
			--exclude 'agent' \
			--exclude '*.sock' \
			--exclude 'op-daemon.sock' \
			"$source/" "$dest/"
	else
		rsync -a "$source" "$dest"
	fi
}

stage_macos_host_state() {
	local stage_home="$1"

	if [[ -d "$HOME/.codex" ]]; then
		mkdir -p "$stage_home/.codex"
		rsync -a \
			--exclude 'cache' \
			--exclude '.tmp' \
			--exclude 'tmp' \
			--exclude 'log' \
			--exclude 'shell_snapshots' \
			--exclude 'config.toml' \
			--exclude 'rules/default.rules' \
			"$HOME/.codex/" "$stage_home/.codex/"
	fi

	stage_path_if_exists "$HOME/.ssh" "$stage_home/.ssh"
	stage_path_if_exists "$HOME/.aws" "$stage_home/.aws"
	stage_path_if_exists "$HOME/.azure" "$stage_home/.azure"
	stage_path_if_exists "$HOME/.kube" "$stage_home/.kube"
	stage_path_if_exists "$HOME/.gnupg" "$stage_home/.gnupg"
	stage_path_if_exists "$HOME/.git-credentials" "$stage_home/.git-credentials"
	stage_path_if_exists "$HOME/.netrc" "$stage_home/.netrc"
	stage_path_if_exists "$HOME/.npmrc" "$stage_home/.npmrc"

	if [[ -f "$HOME/.cargo/credentials.toml" ]]; then
		stage_path_if_exists "$HOME/.cargo/credentials.toml" "$stage_home/.cargo/credentials.toml"
	fi

	if [[ -f "$HOME/.docker/config.json" ]]; then
		stage_path_if_exists "$HOME/.docker/config.json" "$stage_home/.docker/config.json"
	fi

	stage_path_if_exists "$(git_identity_path)" "$stage_home/.config/git/identity"
	stage_path_if_exists "$(git_local_path)" "$stage_home/.config/git/local"

	for config_dir in gh op github-copilot cagent; do
		stage_path_if_exists "$HOME/.config/$config_dir" "$stage_home/.config/$config_dir"
	done
}

import_macos_host_state() {
	local docker_bin="$1"
	local container="$2"
	local force="${DOTCTL_DOCKER_IMPORT_HOST_STATE:-0}"
	local marker="/home/alex/.local/share/dotfiles/host-state-imported"
	local stage_dir stage_home imported_count

	if [[ "$(uname -s)" != "Darwin" ]]; then
		return 0
	fi

	if [[ "$force" != "1" && "$force" != "force" ]] &&
		"$docker_bin" exec "$container" /bin/bash -lc 'test -f "$HOME/.local/share/dotfiles/host-state-imported"' >/dev/null 2>&1; then
		return 0
	fi

	stage_dir="$(mktemp -d)"
	stage_home="$stage_dir/home/alex"
	mkdir -p "$stage_home"
	stage_macos_host_state "$stage_home"

	imported_count="$(find "$stage_home" -mindepth 1 -maxdepth 1 | wc -l | tr -d ' ')"
	if [[ "$imported_count" == "0" ]]; then
		rm -rf "$stage_dir"
		return 0
	fi

	printf 'Importing host auth/config state into %s...\n' "$container"
	"$docker_bin" cp "$stage_home/." "$container:/home/alex/"
	"$docker_bin" exec --user root "$container" /bin/bash -lc '
		set -euo pipefail
		chown -R 1000:1000 /home/alex/.codex /home/alex/.config /home/alex/.ssh /home/alex/.aws /home/alex/.azure /home/alex/.kube /home/alex/.gnupg /home/alex/.cargo /home/alex/.docker /home/alex/.git-credentials /home/alex/.netrc /home/alex/.npmrc 2>/dev/null || true
		[[ -d /home/alex/.ssh ]] && chmod 700 /home/alex/.ssh
		[[ -d /home/alex/.ssh ]] && find /home/alex/.ssh -type f -exec chmod 600 {} +
		[[ -d /home/alex/.gnupg ]] && chmod 700 /home/alex/.gnupg
		mkdir -p /home/alex/.local/share/dotfiles
		chown -R 1000:1000 /home/alex/.local
	'
	"$docker_bin" exec "$container" /bin/bash -lc "printf '%s\n' \"$(date -u +%Y-%m-%dT%H:%M:%SZ)\" > '$marker'"
	rm -rf "$stage_dir"
}

sync_macos_git_identity_to_container() {
	local docker_bin="$1"
	local container="$2"
	local stage_dir stage_home imported_count

	if [[ "$(uname -s)" != "Darwin" ]]; then
		return 0
	fi

	stage_dir="$(mktemp -d)"
	stage_home="$stage_dir/home/alex"
	mkdir -p "$stage_home"
	stage_path_if_exists "$(git_identity_path)" "$stage_home/.config/git/identity"
	stage_path_if_exists "$(git_local_path)" "$stage_home/.config/git/local"

	imported_count="$(find "$stage_home" -mindepth 1 -maxdepth 1 | wc -l | tr -d ' ')"
	if [[ "$imported_count" == "0" ]]; then
		rm -rf "$stage_dir"
		return 0
	fi

	"$docker_bin" cp "$stage_home/." "$container:/home/alex/"
	"$docker_bin" exec --user root "$container" /bin/bash -lc '
		set -euo pipefail
		chown -R 1000:1000 /home/alex/.config/git 2>/dev/null || true
	'
	rm -rf "$stage_dir"
}

hostd_error_response() {
	local message="$1"
	local exit_code="${2:-1}"
	local jq_bin

	jq_bin="$(host_tool_command jq 2>/dev/null || true)"
	if [[ -n "$jq_bin" ]]; then
		"$jq_bin" -cn \
			--arg message "$message" \
			--argjson exit_code "$exit_code" \
			'{ok:false,exit_code:$exit_code,stdout:"",stderr:($message + "\n")}'
	else
		printf '{"ok":false,"exit_code":%s,"stdout":"","stderr":"hostd error before jq was available\\n"}\n' "$exit_code"
	fi
}

hostd_command_response() {
	local exit_code="$1"
	local stdout_file="$2"
	local stderr_file="$3"
	local jq_bin

	jq_bin="$(host_tool_command jq)"
	"$jq_bin" -cn \
		--argjson exit_code "$exit_code" \
		--rawfile stdout "$stdout_file" \
		--rawfile stderr "$stderr_file" \
		'{ok:($exit_code == 0),exit_code:$exit_code,stdout:$stdout,stderr:$stderr}'
}

run_hostd_handle() {
	local request jq_bin action stdout_file stderr_file exit_code op_bin
	local args=()
	local arg

	if ! IFS= read -r request; then
		hostd_error_response 'empty hostd request' 2
		return 0
	fi

	jq_bin="$(host_tool_command jq 2>/dev/null || true)"
	if [[ -z "$jq_bin" ]]; then
		hostd_error_response 'jq is not available on the host' 127
		return 0
	fi

	if ! action="$(printf '%s' "$request" | "$jq_bin" -er '.action // empty' 2>/dev/null)"; then
		hostd_error_response 'invalid hostd request: missing action' 2
		return 0
	fi

	if ! printf '%s' "$request" | "$jq_bin" -e '(.args // []) | type == "array" and all(.[]; type == "string")' >/dev/null 2>&1; then
		hostd_error_response 'invalid hostd request: args must be an array of strings' 2
		return 0
	fi

	while IFS= read -r arg; do
		args+=("$arg")
	done < <(printf '%s' "$request" | "$jq_bin" -r '.args[]?')

	case "$action" in
		ping)
			stdout_file="$(mktemp)"
			stderr_file="$(mktemp)"
			printf 'pong\n' >"$stdout_file"
			: >"$stderr_file"
			hostd_command_response 0 "$stdout_file" "$stderr_file"
			rm -f "$stdout_file" "$stderr_file"
			;;
		op)
			if ! op_bin="$(onepassword_cli_command 2>/dev/null)"; then
				hostd_error_response '1Password CLI is not available on the host' 127
				return 0
			fi
			stdout_file="$(mktemp)"
			stderr_file="$(mktemp)"
			if "$op_bin" "${args[@]}" >"$stdout_file" 2>"$stderr_file"; then
				exit_code=0
			else
				exit_code=$?
			fi
			hostd_command_response "$exit_code" "$stdout_file" "$stderr_file"
			rm -f "$stdout_file" "$stderr_file"
			;;
		*)
			hostd_error_response "unsupported hostd action: $action" 2
			;;
	esac
}

hostd_client_socket() {
	if [[ -n "${DOTFILES_HOSTD_SOCK:-}" ]]; then
		printf '%s\n' "$DOTFILES_HOSTD_SOCK"
	elif [[ -S "$(dotfiles_hostd_container_sock)" || -e "$(dotfiles_hostd_container_sock)" ]]; then
		dotfiles_hostd_container_sock
	else
		dotfiles_hostd_sock
	fi
}

run_host_client() {
	local subcommand="${1:-}"
	local action request response socket socat_bin jq_bin exit_code

	[[ -n "$subcommand" ]] || {
		printf 'Usage: dotctl host <ping|op ...>\n' >&2
		return 2
	}
	shift || true

	case "$subcommand" in
		ping)
			action="ping"
			if (($#)); then
				printf 'Usage: dotctl host ping\n' >&2
				return 2
			fi
			;;
		op)
			action="op"
			;;
		*)
			printf 'Unsupported host command: %s\n' "$subcommand" >&2
			printf 'Usage: dotctl host <ping|op ...>\n' >&2
			return 2
			;;
	esac

	if ! jq_bin="$(host_tool_command jq 2>/dev/null)"; then
		printf 'jq is required for dotctl host. Rebuild the workshop image or install jq on the host.\n' >&2
		return 127
	fi
	if ! socat_bin="$(host_tool_command socat 2>/dev/null)"; then
		printf 'socat is required for dotctl host. Rebuild the workshop image or install socat on the host.\n' >&2
		return 127
	fi

	socket="$(hostd_client_socket)"
	if [[ ! -S "$socket" ]]; then
		printf 'dotfiles host socket is not available at %s.\n' "$socket" >&2
		printf 'From the macOS host, run: ~/.dotfiles/scripts/dotctl apply --recreate macos-docker\n' >&2
		return 1
	fi

	request="$("$jq_bin" -cn --arg action "$action" '$ARGS.positional as $args | {action:$action,args:$args}' --args -- "$@")"
	if ! response="$(printf '%s\n' "$request" | "$socat_bin" - "UNIX-CONNECT:$socket")"; then
		printf 'dotfiles host request failed while connecting to %s.\n' "$socket" >&2
		return 1
	fi

	if ! printf '%s' "$response" | "$jq_bin" -e 'type == "object" and has("exit_code")' >/dev/null 2>&1; then
		printf 'dotfiles hostd returned an invalid response:\n%s\n' "$response" >&2
		return 1
	fi

	printf '%s' "$response" | "$jq_bin" -rj '.stdout // ""'
	printf '%s' "$response" | "$jq_bin" -rj '.stderr // ""' >&2
	exit_code="$(printf '%s' "$response" | "$jq_bin" -r '.exit_code')"
	return "$exit_code"
}

macos_docker_image() {
	printf '%s\n' "${DOTCTL_DOCKER_IMAGE:-dotfiles-workshop:local}"
}

macos_docker_builder_image() {
	printf '%s\n' "${DOTCTL_DOCKER_BUILDER_IMAGE:-nixos/nix:latest}"
}

macos_docker_builder_store() {
	printf '%s\n' "${DOTCTL_DOCKER_BUILDER_STORE:-dotfiles-nix-builder-store}"
}

macos_docker_nix_target() {
	printf '%s\n' "${DOTCTL_DOCKER_NIX_TARGET:-.#docker-linux}"
}

macos_docker_platform() {
	printf '%s\n' "${DOTCTL_DOCKER_PLATFORM:-linux/amd64}"
}

macos_docker_container() {
	printf '%s\n' "${DOTCTL_DOCKER_CONTAINER:-dotfiles-workshop}"
}

macos_docker_work_root() {
	if [[ -n "${DOTCTL_DOCKER_WORK:-}" ]]; then
		printf '%s\n' "$DOTCTL_DOCKER_WORK"
	else
		printf '%s\n' "$HOME/code"
	fi
}

macos_docker_socket() {
	local docker_host="${DOCKER_HOST:-}"

	if [[ "$docker_host" == unix://* && -S "${docker_host#unix://}" ]]; then
		printf '%s\n' "${docker_host#unix://}"
	elif [[ -S "$HOME/.docker/run/docker.sock" ]]; then
		printf '%s\n' "$HOME/.docker/run/docker.sock"
	elif [[ -S /var/run/docker.sock ]]; then
		printf '/var/run/docker.sock\n'
	fi
}

macos_docker_ssh_auth_sock() {
	case "${DOTCTL_DOCKER_SSH_AUTH_SOCK:-}" in
		0 | false | FALSE | no | NO)
			return 0
			;;
		?*)
			printf '%s\n' "$DOTCTL_DOCKER_SSH_AUTH_SOCK"
			return 0
			;;
	esac

	if [[ "$(uname -s)" == "Darwin" ]]; then
		printf '/run/host-services/ssh-auth.sock\n'
	fi
}

validate_macos_docker_work_root() {
	local work_root="$1"
	local home_real work_real

	if [[ -z "$work_root" || "$work_root" == "/" || "$work_root" == "$HOME" ]]; then
		printf 'Refusing unsafe Docker work root: %s\n' "$work_root" >&2
		return 1
	fi

	mkdir -p "$work_root"
	home_real="$(cd "$HOME" && pwd -P)"
	work_real="$(cd "$work_root" && pwd -P)"

	case "$work_real" in
		"$home_real"/*) ;;
		*)
			printf 'Refusing Docker work root outside HOME: %s\n' "$work_real" >&2
			return 1
			;;
	esac
}

stage_repo_for_docker_build() {
	local stage_source="$1"

	mkdir -p "$stage_source"
	rsync -a --delete \
		--exclude '.git' \
		--exclude '.direnv' \
		--exclude '.dotctl-build' \
		--exclude 'result' \
		--exclude 'result-*' \
		"$REPO_ROOT/" "$stage_source/"
}

tar_supports_create_option() {
	local option="$1"
	local probe_dir

	probe_dir="$(mktemp -d)"
	touch "$probe_dir/probe"
	if tar "$option" -C "$probe_dir" -cf /dev/null . >/dev/null 2>&1; then
		rm -rf "$probe_dir"
		return 0
	fi
	rm -rf "$probe_dir"
	return 1
}

tar_repo_stream() {
	local source="$1"
	local tar_args=()

	if tar_supports_create_option --disable-copyfile; then
		tar_args+=(--disable-copyfile)
	fi
	if tar_supports_create_option --no-xattrs; then
		tar_args+=(--no-xattrs)
	fi

	COPYFILE_DISABLE=1 tar "${tar_args[@]}" -C "$source" -cf - .
}

build_macos_docker_image() {
	local docker_bin="$1"
	local image="$2"
	local platform="$3"
	local builder_image builder_store target stage_dir stage_source image_tar
	local platform_args=()

	builder_image="$(macos_docker_builder_image)"
	builder_store="$(macos_docker_builder_store)"
	target="$(macos_docker_nix_target)"
	stage_dir="$(mktemp -d)"
	stage_source="$stage_dir/source"
	image_tar="$stage_dir/image.tar"
	if [[ -n "$platform" ]]; then
		platform_args=(--platform "$platform")
	fi

	stage_repo_for_docker_build "$stage_source"

	printf 'Building %s from %s with %s...\n' "$image" "$REPO_ROOT" "$builder_image"
	if ! tar_repo_stream "$stage_source" |
		"$docker_bin" run --rm -i \
			"${platform_args[@]}" \
			--security-opt seccomp=unconfined \
			-v "$builder_store:/nix" \
			-e DOTCTL_NIX_TARGET="$target" \
			--entrypoint /bin/sh \
			"$builder_image" \
			-lc '
				set -eu
				mkdir -p /work
				tar -C /work -xf -
				cd /work
				out="$(nix --extra-experimental-features "nix-command flakes" build --option sandbox false --option filter-syscalls false --no-link --print-out-paths "$DOTCTL_NIX_TARGET" 2>/dev/stderr)"
				cat "$out"
			' >"$image_tar"; then
		rm -rf "$stage_dir"
		return 1
	fi

	"$docker_bin" load -i "$image_tar" >/dev/null
	if [[ "$image" != "ghcr.io/alexallocated/dotfiles-linux:latest" ]]; then
		"$docker_bin" tag ghcr.io/alexallocated/dotfiles-linux:latest "$image"
	fi
	rm -rf "$stage_dir"
}

ensure_macos_docker_image() {
	local docker_bin="$1"
	local image="$2"
	local platform="$3"
	local rebuild="${4:-0}"

	if [[ "$rebuild" == "1" || "${DOTCTL_DOCKER_REBUILD:-0}" == "1" ]]; then
		build_macos_docker_image "$docker_bin" "$image" "$platform"
		return 0
	fi

	if "$docker_bin" image inspect "$image" >/dev/null 2>&1; then
		return 0
	fi

	build_macos_docker_image "$docker_bin" "$image" "$platform"
}

run_macos_docker() {
	local recreate="${1:-0}"
	local rebuild="${2:-$recreate}"
	local announce="${3:-1}"
	local docker_bin image platform container work_root home_volume docker_socket ssh_auth_sock hostd_sock
	local platform_args=()
	local docker_socket_args=()
	local ssh_auth_sock_args=()
	local hostd_sock_args=()

	ensure_git_identity
	apply_macos_host_links
	ensure_wezterm
	ensure_1password
	ensure_dotfiles_hostd

	docker_bin="$(ensure_docker)"
	image="$(macos_docker_image)"
	platform="$(macos_docker_platform)"
	container="$(macos_docker_container)"
	work_root="$(macos_docker_work_root)"
	validate_macos_docker_work_root "$work_root"
	home_volume="${container}-home"
	docker_socket="$(macos_docker_socket)"
	ssh_auth_sock="$(macos_docker_ssh_auth_sock)"
	hostd_sock="$(macos_docker_hostd_sock)"
	if [[ -n "$platform" ]]; then
		platform_args=(--platform "$platform")
	fi
	if [[ -n "$docker_socket" ]]; then
		docker_socket_args=(-v "$docker_socket:/var/run/docker.sock" -e DOCKER_HOST=unix:///var/run/docker.sock --group-add 0)
	fi
	if [[ -n "$ssh_auth_sock" ]]; then
		ssh_auth_sock_args=(-v "$ssh_auth_sock:/run/host-services/ssh-auth.sock" -e SSH_AUTH_SOCK=/run/host-services/ssh-auth.sock)
	fi
	if [[ -n "$hostd_sock" ]]; then
		hostd_sock_args=(-v "$hostd_sock:$(dotfiles_hostd_container_sock)" -e "DOTFILES_HOSTD_SOCK=$(dotfiles_hostd_container_sock)")
	fi

	ensure_macos_docker_image "$docker_bin" "$image" "$platform" "$rebuild"
	"$docker_bin" volume create "$home_volume" >/dev/null
	"$docker_bin" run --rm "${platform_args[@]}" --user root --workdir / \
		-v "$home_volume:/home" \
		"$image" \
		/bin/bash -lc '[[ -L /home/alex ]] && rm /home/alex; mkdir -p /home/alex && chown -R 1000:1000 /home/alex'

	if "$docker_bin" container inspect "$container" >/dev/null 2>&1; then
		if [[ "$recreate" == "1" ]]; then
			"$docker_bin" rm -f "$container" >/dev/null
		else
			"$docker_bin" start "$container" >/dev/null
			if ! "$docker_bin" exec "$container" /bin/bash -lc 'test -w "$HOME"' >/dev/null 2>&1; then
				printf 'Existing container has an unwritable home; recreating %s...\n' "$container" >&2
				"$docker_bin" rm -f "$container" >/dev/null
			elif [[ "$("$docker_bin" inspect -f '{{.Config.Image}}' "$container")" != "$image" ]]; then
				printf 'Existing container was created from a different image; recreating %s...\n' "$container" >&2
				"$docker_bin" rm -f "$container" >/dev/null
			elif ! "$docker_bin" inspect -f '{{range .Mounts}}{{println .Destination}}{{end}}' "$container" | grep -qx '/home/alex/code'; then
				printf 'Existing container does not mount ~/code; recreating %s...\n' "$container" >&2
				"$docker_bin" rm -f "$container" >/dev/null
			elif [[ -n "$docker_socket" ]] && ! "$docker_bin" inspect -f '{{range .Mounts}}{{println .Destination}}{{end}}' "$container" | grep -qx '/var/run/docker.sock'; then
				printf 'Existing container does not mount the Docker socket; recreating %s...\n' "$container" >&2
				"$docker_bin" rm -f "$container" >/dev/null
			elif [[ -n "$docker_socket" ]] && ! "$docker_bin" inspect -f '{{range .HostConfig.GroupAdd}}{{println .}}{{end}}' "$container" | grep -qx '0'; then
				printf 'Existing container cannot access the Docker socket as alex; recreating %s...\n' "$container" >&2
				"$docker_bin" rm -f "$container" >/dev/null
			elif [[ -n "$ssh_auth_sock" ]] && ! "$docker_bin" inspect -f '{{range .Mounts}}{{println .Destination}}{{end}}' "$container" | grep -qx '/run/host-services/ssh-auth.sock'; then
				printf 'Existing container does not mount the host SSH agent; recreating %s...\n' "$container" >&2
				"$docker_bin" rm -f "$container" >/dev/null
			elif [[ -n "$ssh_auth_sock" ]] && ! "$docker_bin" inspect -f '{{range .Config.Env}}{{println .}}{{end}}' "$container" | grep -qx 'SSH_AUTH_SOCK=/run/host-services/ssh-auth.sock'; then
				printf 'Existing container does not export the host SSH agent socket; recreating %s...\n' "$container" >&2
				"$docker_bin" rm -f "$container" >/dev/null
			elif [[ -n "$hostd_sock" ]] && ! "$docker_bin" inspect -f '{{range .Mounts}}{{println .Destination}}{{end}}' "$container" | grep -qx "$(dotfiles_hostd_container_sock)"; then
				printf 'Existing container does not mount the dotfiles host socket; recreating %s...\n' "$container" >&2
				"$docker_bin" rm -f "$container" >/dev/null
			elif [[ -n "$hostd_sock" ]] && ! "$docker_bin" inspect -f '{{range .Config.Env}}{{println .}}{{end}}' "$container" | grep -qx "DOTFILES_HOSTD_SOCK=$(dotfiles_hostd_container_sock)"; then
				printf 'Existing container does not export the dotfiles host socket path; recreating %s...\n' "$container" >&2
				"$docker_bin" rm -f "$container" >/dev/null
			else
				provision_macos_docker_container "$docker_bin" "$container"
				import_macos_host_state "$docker_bin" "$container"
				sync_macos_git_identity_to_container "$docker_bin" "$container"
				prime_macos_docker_neovim "$docker_bin" "$container" "$announce"
				write_macos_host_profile macos-docker
				if [[ "$announce" == "1" ]]; then
					printf 'Container %s is ready. Enter it with: dotctl shell macos-docker\n' "$container"
				fi
				return 0
			fi
		fi
	fi

	"$docker_bin" run -d \
		"${platform_args[@]}" \
		--name "$container" \
		--hostname "$container" \
		--workdir /home/alex/code \
		-e DOTFILES_ROOT=/home/alex/.dotfiles \
		-e TERM="${TERM:-xterm-256color}" \
		-v "$home_volume:/home" \
		-v "$REPO_ROOT:/home/alex/.dotfiles" \
		-v "$work_root:/home/alex/code" \
		"${docker_socket_args[@]}" \
		"${ssh_auth_sock_args[@]}" \
		"${hostd_sock_args[@]}" \
		"$image" \
		sleep infinity >/dev/null

	provision_macos_docker_container "$docker_bin" "$container"
	import_macos_host_state "$docker_bin" "$container"
	sync_macos_git_identity_to_container "$docker_bin" "$container"
	prime_macos_docker_neovim "$docker_bin" "$container" "$announce"
	write_macos_host_profile macos-docker
	if [[ "$announce" == "1" ]]; then
		printf 'Container %s is ready. Enter it with: dotctl shell macos-docker\n' "$container"
	fi
}

run_workshop_update() {
	local docker_bin image platform
	local git_status
	local docker_wrapper=""

	if ! command_exists git || ! git -C "$REPO_ROOT" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
		printf 'No Git checkout found at %s; skipping dotfiles pull.\n' "$REPO_ROOT" >&2
	else
		git_status="$(git -C "$REPO_ROOT" status --porcelain)"
	fi

	if [[ -n "${git_status:-}" ]]; then
		printf 'Dotfiles checkout has local changes; leaving Git state unchanged.\n' >&2
	elif [[ -d "$REPO_ROOT/.git" ]]; then
		git -C "$REPO_ROOT" pull --ff-only
	fi

	if ! docker_bin="$(docker_command 2>/dev/null)"; then
		printf 'Docker is not available in this shell; rebuild from the host with: dotctl apply --update macos-docker\n' >&2
		return 1
	elif ! "$docker_bin" info >/dev/null 2>&1; then
		if command_exists sudo && sudo "$docker_bin" info >/dev/null 2>&1; then
			docker_wrapper="$(mktemp)"
			printf '#!/usr/bin/env bash\nexec sudo %q "$@"\n' "$docker_bin" >"$docker_wrapper"
			chmod +x "$docker_wrapper"
			docker_bin="$docker_wrapper"
		else
			printf 'Docker is not reachable in this shell; rebuild from the host with: dotctl apply --update macos-docker\n' >&2
			return 1
		fi
	fi

	image="$(macos_docker_image)"
	platform="$(macos_docker_platform)"
	build_macos_docker_image "$docker_bin" "$image" "$platform"
	[[ -z "$docker_wrapper" ]] || rm -f "$docker_wrapper"
	printf 'Built %s from %s.\n' "$image" "$REPO_ROOT"
	printf 'Restart this workshop from the host with: dotctl apply --recreate macos-docker\n'
}

shell_macos_docker() {
	local docker_bin container
	run_macos_docker 0 0 0
	docker_bin="$(docker_command)"
	container="$(macos_docker_container)"
	exec "$docker_bin" exec -it "$container" /bin/zsh -l
}

apply_profile() {
	local profile="$1"
	local flake_ref

	case "$profile" in
		macos-docker)
			run_macos_docker 0
			;;
		nixos-wsl)
			flake_ref="$(flake_ref_for_profile "$profile")"
			require_command sudo
			require_command nixos-rebuild
			sudo nixos-rebuild boot --flake "$flake_ref"
			printf 'NixOS-WSL generation installed. Restart the distro with: wsl.exe -t NixOS\n'
			;;
		darwin-macos | darwin-macos-intel)
			flake_ref="$(flake_ref_for_profile "$profile")"
			require_command sudo
			require_command darwin-rebuild
			local darwin_rebuild
			darwin_rebuild="$(command -v darwin-rebuild)"
			sudo "$darwin_rebuild" switch --flake "$flake_ref"
			;;
		*)
			flake_ref="$(flake_ref_for_profile "$profile")"
			require_command home-manager
			home-manager switch -b hm-backup --flake "$flake_ref"
			;;
	esac
}

run_check() {
	require_command nix
	nix flake check "$REPO_ROOT"
}

refresh_flake_lock() {
	require_command nix
	printf 'Refreshing flake inputs...\n'
	nix flake update --flake "$REPO_ROOT"
}

refresh_neovim_runtime() {
	local nvim_config="$REPO_ROOT/nvim"
	[[ -f "$nvim_config/lazy-lock.json" ]] || return 0

	if ! command_exists nvim; then
		printf 'Neovim is not available; skipping Neovim runtime refresh.\n' >&2
		return 0
	fi

	local tmp_xdg_config
	tmp_xdg_config="$(mktemp -d)"
	(
		trap 'rm -rf "$tmp_xdg_config"' EXIT
		ln -s "$nvim_config" "$tmp_xdg_config/nvim"

		printf 'Refreshing Neovim plugin pins, Mason registry, and Treesitter parsers...\n'
		DOTFILES_NVIM_AUTOMATION=1 XDG_CONFIG_HOME="$tmp_xdg_config" nvim --headless "+set nomore" "+Lazy! update" "+MasonUpdate" "+TSUpdateSync" "+lua require(\"config.bootstrap\").wait_for_mason()" +qa
	)
}

run_update() {
	refresh_flake_lock
	refresh_neovim_runtime
}

print_repo_status() {
	if command_exists git && git -C "$REPO_ROOT" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
		printf 'Repository changes after update/apply:\n'
		git -C "$REPO_ROOT" status --short
	fi
}

require_command() {
	if ! command_exists "$1"; then
		printf 'Required command not found: %s\n' "$1" >&2
		exit 1
	fi
}

run_doctor() {
	printf 'dotfiles repo: %s\n' "$REPO_ROOT"
	printf 'detected profile: %s\n' "$(detect_profile)"
	printf 'uname: %s\n' "$(uname -a)"
	printf 'nix: '
	if command_exists nix; then
		nix --version
	else
		printf 'not found\n'
	fi

	local cmd_path
	for cmd in zsh git gh op ssh nvim bun node rustc cargo rust-analyzer go dotnet wezterm docker; do
		if [[ "$cmd" == "op" ]] && cmd_path="$(onepassword_cli_command 2>/dev/null)"; then
			printf '%-12s %s\n' "$cmd" "$cmd_path"
		elif command_exists "$cmd"; then
			printf '%-12s %s\n' "$cmd" "$(command -v "$cmd")"
		else
			printf '%-12s missing\n' "$cmd"
		fi
	done
	local git_identity git_identity_name git_identity_email
	git_identity="$(git_identity_path)"
	git_identity_name="$(git_config_value user.name "$git_identity")"
	git_identity_email="$(git_config_value user.email "$git_identity")"
	if [[ -n "$git_identity_name" && -n "$git_identity_email" ]]; then
		printf '%-12s %s <%s>\n' "git-id" "$git_identity_name" "$git_identity_email"
	else
		printf '%-12s missing (%s)\n' "git-id" "$git_identity"
	fi
	if [[ "$(uname -s)" == "Darwin" ]]; then
		if [[ -d /Applications/1Password.app ]]; then
			printf '%-12s %s\n' "1password" "/Applications/1Password.app"
		else
			printf '%-12s missing\n' "1password"
		fi
		if [[ -S "$(dotfiles_hostd_sock)" ]]; then
			printf '%-12s %s\n' "hostd" "$(dotfiles_hostd_sock)"
		else
			printf '%-12s missing\n' "hostd"
		fi
	elif [[ -n "${DOTFILES_HOSTD_SOCK:-}" || -e "$(dotfiles_hostd_container_sock)" ]]; then
		if [[ -S "$(hostd_client_socket)" ]]; then
			printf '%-12s %s\n' "hostd" "$(hostd_client_socket)"
		else
			printf '%-12s missing\n' "hostd"
		fi
	fi

	if [[ "$(detect_profile)" == "macos-docker" ]] && docker_bin="$(docker_command 2>/dev/null)"; then
		local container
		container="$(macos_docker_container)"
		if ! "$docker_bin" info >/dev/null 2>&1; then
			printf 'container    unavailable; Docker is not ready or the socket is inaccessible\n'
		elif "$docker_bin" container inspect "$container" >/dev/null 2>&1; then
			printf 'container    %s\n' "$("$docker_bin" inspect -f '{{.Name}} {{.State.Status}} {{.Config.Image}}' "$container" | sed 's#^/##')"
			printf 'ssh-agent    %s\n' "$("$docker_bin" exec "$container" /bin/bash -lc 'if [[ -S /run/host-services/ssh-auth.sock ]]; then printf mounted; elif [[ -e /run/host-services/ssh-auth.sock ]]; then printf present-not-socket; else printf missing; fi' 2>/dev/null || printf unavailable)"
			printf 'hostd-mount  %s\n' "$("$docker_bin" exec "$container" /bin/bash -lc 'sock="${DOTFILES_HOSTD_SOCK:-/run/host-services/dotfiles-hostd.sock}"; if [[ -S "$sock" ]]; then printf mounted; elif [[ -e "$sock" ]]; then printf present-not-socket; else printf missing; fi' 2>/dev/null || printf unavailable)"
		else
			printf 'container    %s not created\n' "$container"
		fi
	fi

	if [[ -n "${WSL_DISTRO_NAME:-}" ]]; then
		printf 'WSL_DISTRO_NAME=%s\n' "$WSL_DISTRO_NAME"
		if command_exists powershell.exe; then
			powershell.exe -NoLogo -NoProfile -Command 'Get-PSDrive -PSProvider FileSystem | Select-Object Name,Free,Used,Root | ConvertTo-Json -Compress' | tr -d '\r'
			printf '\n'
		fi
	fi
}

main() {
	local command="${1:-}"
	[[ -n "$command" ]] || {
		usage
		exit 2
	}
	shift || true

	case "$command" in
		apply)
			local profile=""
			local update=0
			local recreate=0
			while (($#)); do
				case "$1" in
					--update)
						update=1
						;;
					--recreate)
						recreate=1
						;;
					*)
						profile="$1"
						;;
				esac
				shift
			done
			profile="${profile:-$(detect_profile)}"
			if [[ "$profile" != "macos-docker" ]]; then
				ensure_git_identity
			fi
			if ((update)); then
				if [[ "$profile" == "macos-docker" ]]; then
					run_macos_docker 1 1
				else
					run_update
					run_check
				fi
			elif ((recreate)) && [[ "$profile" == "macos-docker" ]]; then
				run_macos_docker 1 0
			fi
			if [[ "$profile" != "macos-docker" || ( "$update" != "1" && "$recreate" != "1" ) ]]; then
				apply_profile "$profile"
			fi
			if ((update)); then
				print_repo_status
			fi
			;;
		shell)
			local profile="${1:-$(detect_profile)}"
			case "$profile" in
				macos-docker)
					shell_macos_docker
					;;
				*)
					printf 'No interactive shell handler for profile: %s\n' "$profile" >&2
					exit 2
					;;
			esac
			;;
		import-host-state)
			local profile="${1:-$(detect_profile)}"
			case "$profile" in
				macos-docker)
					local docker_bin container
					run_macos_docker 0 0 0
					docker_bin="$(docker_command)"
					container="$(macos_docker_container)"
					DOTCTL_DOCKER_IMPORT_HOST_STATE=force import_macos_host_state "$docker_bin" "$container"
					;;
				*)
					printf 'No host-state import handler for profile: %s\n' "$profile" >&2
					exit 2
					;;
			esac
			;;
		workshop-update)
			run_workshop_update
			;;
		host)
			run_host_client "$@"
			;;
		hostd-handle)
			run_hostd_handle
			;;
		update)
			run_update
			print_repo_status
			;;
		check)
			run_check
			;;
		doctor)
			run_doctor
			;;
		-h | --help | help)
			usage
			;;
		*)
			printf 'Unknown command: %s\n' "$command" >&2
			usage >&2
			exit 2
			;;
	esac
}

main "$@"
